# PostgreSQL connection string
# Example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Optional: set false only if your local database does not need SSL
DATABASE_SSL=true

# PostHog project API key used by frontend and backend event capture
POSTHOG_PUBLIC_KEY=

# Custom/self-hosted PostHog base URL (example: https://posthog.yourdomain.com)
POSTHOG_HOST=
