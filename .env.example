# PostgreSQL connection string
# Example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Optional: set false only if your local database does not need SSL
DATABASE_SSL=true

# Resend API key for sending verification emails
RESEND_API_KEY=

# Verified sender address in Resend (e.g. no-reply@yourdomain.com)
FROM_EMAIL=

# Public app URL used in verification email links
# Example: https://job-apply-eta.vercel.app
APP_BASE_URL=
