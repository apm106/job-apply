# PostgreSQL connection string
# Example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Optional: set false only if your local database does not need SSL
DATABASE_SSL=true

# PostHog project API key used by frontend event capture
POSTHOG_PUBLIC_KEY=

# PostHog base URL (example: https://us.i.posthog.com)
POSTHOG_HOST=

# Supabase auth settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Public app base URL for auth redirects
APP_BASE_URL=

# Optional cookie domain override
AUTH_COOKIE_DOMAIN=
